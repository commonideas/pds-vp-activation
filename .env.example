# Vercel → Project → Settings → Environment Variables

SHOPIFY_STORE=panierdessens.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxx
# Default: Customer Accounts login. Use SHOPIFY_LOGIN_STYLE=legacy for /account/login?return_url=
SHOPIFY_LOGIN_STYLE=customer_authentication
SHOP_URL=https://panierdessens.com
SHOP_HOME_PATH=/
# Live (after publish): assign template collection.vp on the collection in Shopify Admin
VP_COLLECTION_PATH=/collections/vp-h7k3m9
# Draft theme testing only: VP_COLLECTION_PATH=/collections/vp-h7k3m9?view=vp
KLAVIYO_WEBHOOK_SECRET=your-random-secret
# Klaviyo → Settings → API keys → Private API key (scopes: profiles:read, profiles:write)
KLAVIYO_PRIVATE_API_KEY=your-private-api-key
ACTIVATION_BASE_URL=https://pds-vp-activation.vercel.app

# Supabase — manual setup OR auto from Vercel Supabase integration:
# NEXT_PUBLIC_SUPABASE_URL          (auto)
# SUPABASE_SECRET_KEY               (auto — service role, use on server only)
# SUPABASE_SERVICE_ROLE_KEY         (manual alias, also works)
# SUPABASE_URL                      (manual alias, also works)
